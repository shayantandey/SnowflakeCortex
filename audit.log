{"ts": "2026-03-17T12:20:45.475001+00:00", "user": "shayantan", "question": "What is the total order amount and total order count by order channel year to date?", "sql": "WITH __order_header AS (\n  SELECT\n    order_id,\n    order_channel,\n    order_ts,\n    order_amount\n  FROM tasty_bytes.raw_pos.order_header\n)\nSELECT\n  order_channel,\n  SUM(order_amount) AS total_order_amount,\n  COUNT(DISTINCT order_id) AS total_order_count\nFROM __order_header\nWHERE\n  order_ts >= DATE_TRUNC('YEAR', CURRENT_DATE)\n  AND order_ts < CURRENT_DATE + INTERVAL '1 DAY'\nGROUP BY\n  order_channel\nORDER BY\n  total_order_amount DESC NULLS LAST\n -- Generated by Cortex Analyst (request_id: 55bb44a2-3920-489b-89eb-0f0e730b9e61)\n;", "row_count": 0, "error": ""}
{"ts": "2026-03-17T12:21:49.931511+00:00", "user": "shayantan", "question": "How many distinct trucks are operating in each country, broken down by whether they are electric vehicles or not?", "sql": "WITH __truck AS (\n  SELECT\n    truck_id,\n    country,\n    ev_flag\n  FROM tasty_bytes.raw_pos.truck\n)\nSELECT\n  t.country,\n  t.ev_flag,\n  COUNT(DISTINCT t.truck_id) AS distinct_truck_count\nFROM __truck AS t\nGROUP BY\n  t.country,\n  t.ev_flag\nORDER BY\n  t.country,\n  t.ev_flag\n -- Generated by Cortex Analyst (request_id: 7f9a1656-fe23-4c4e-ba8d-a30723d1645e)\n;", "row_count": 30, "error": ""}
{"ts": "2026-03-17T12:27:44.651300+00:00", "user": "shayantan", "question": "What is the average sale price and cost of goods for each item category in the menu?", "sql": "WITH __menu AS (\n  SELECT\n    item_category,\n    sale_price_usd,\n    cost_of_goods_usd\n  FROM tasty_bytes.raw_pos.menu\n)\nSELECT\n  m.item_category,\n  AVG(m.sale_price_usd) AS avg_sale_price_usd,\n  AVG(m.cost_of_goods_usd) AS avg_cost_of_goods_usd\nFROM __menu AS m\nGROUP BY\n  m.item_category\nORDER BY\n  m.item_category\n -- Generated by Cortex Analyst (request_id: 720d7f7d-1f9e-41f4-9062-813080e1cab0)\n;", "row_count": 4, "error": ""}
{"ts": "2026-03-17T12:28:09.813538+00:00", "user": "shayantan", "question": "What is the average sale price and cost of goods for each item category in the menu broken down by month?", "sql": "WITH __order_detail AS (\n  SELECT\n    order_id,\n    menu_item_id\n  FROM tasty_bytes.raw_pos.order_detail\n), __order_header AS (\n  SELECT\n    order_id,\n    order_ts\n  FROM tasty_bytes.raw_pos.order_header\n), __menu AS (\n  SELECT\n    menu_item_id,\n    item_category,\n    sale_price_usd,\n    cost_of_goods_usd\n  FROM tasty_bytes.raw_pos.menu\n), order_menu AS (\n  SELECT\n    od.order_id,\n    od.menu_item_id,\n    oh.order_ts,\n    m.item_category,\n    m.sale_price_usd,\n    m.cost_of_goods_usd\n  FROM __order_detail AS od\n  LEFT OUTER JOIN __order_header AS oh\n    ON od.order_id = oh.order_id\n  LEFT OUTER JOIN __menu AS m\n    ON od.menu_item_id = m.menu_item_id\n)\nSELECT\n  DATE_TRUNC('MONTH', order_ts) AS month,\n  item_category,\n  AVG(sale_price_usd) AS avg_sale_price_usd,\n  AVG(cost_of_goods_usd) AS avg_cost_of_goods_usd\nFROM order_menu\nGROUP BY\n  DATE_TRUNC('MONTH', order_ts),\n  item_category\nORDER BY\n  month DESC NULLS LAST,\n  item_category\n -- Generated by Cortex Analyst (request_id: cf3f7ee1-f53b-4401-8247-23da6d3b3fa3)\n;", "row_count": 152, "error": ""}
{"ts": "2026-03-17T12:28:45.683766+00:00", "user": "shayantan", "question": "What are the top 10 for what is the average sale price and cost of goods for each item category in the menu broken down by month?", "sql": "WITH __order_detail AS (\n  SELECT\n    order_id,\n    menu_item_id\n  FROM tasty_bytes.raw_pos.order_detail\n), __order_header AS (\n  SELECT\n    order_id,\n    order_ts\n  FROM tasty_bytes.raw_pos.order_header\n), __menu AS (\n  SELECT\n    menu_item_id,\n    item_category,\n    sale_price_usd,\n    cost_of_goods_usd\n  FROM tasty_bytes.raw_pos.menu\n), menu_monthly AS (\n  SELECT\n    DATE_TRUNC('MONTH', oh.order_ts) AS month,\n    m.item_category,\n    m.menu_item_id,\n    ANY_VALUE(m.sale_price_usd) AS sale_price_usd,\n    ANY_VALUE(m.cost_of_goods_usd) AS cost_of_goods_usd\n  FROM __order_detail AS od\n  LEFT OUTER JOIN __order_header AS oh\n    ON od.order_id = oh.order_id\n  LEFT OUTER JOIN __menu AS m\n    ON od.menu_item_id = m.menu_item_id\n  GROUP BY\n    DATE_TRUNC('MONTH', oh.order_ts),\n    m.item_category,\n    m.menu_item_id\n), monthly_category AS (\n  SELECT\n    month,\n    item_category,\n    AVG(sale_price_usd) AS avg_sale_price_usd,\n    AVG(cost_of_goods_usd) AS avg_cost_of_goods_usd\n  FROM menu_monthly\n  GROUP BY\n    month,\n    item_category\n)\nSELECT\n  month,\n  item_category,\n  avg_sale_price_usd,\n  avg_cost_of_goods_usd\nFROM monthly_category\nORDER BY\n  avg_sale_price_usd DESC NULLS LAST\nLIMIT 10\n -- Generated by Cortex Analyst (request_id: f469d472-d743-47dc-af3b-6a69135abcd4)\n;", "row_count": 10, "error": ""}
{"ts": "2026-03-17T12:29:06.855421+00:00", "user": "shayantan", "question": "What are the top 10 for what is the average sale price and cost of goods for each item category in the menu broken down by month broken down by category?", "sql": "WITH __order_detail AS (\n  SELECT\n    order_id,\n    menu_item_id\n  FROM tasty_bytes.raw_pos.order_detail\n), __order_header AS (\n  SELECT\n    order_id,\n    order_ts\n  FROM tasty_bytes.raw_pos.order_header\n), __menu AS (\n  SELECT\n    menu_item_id,\n    item_category,\n    sale_price_usd,\n    cost_of_goods_usd\n  FROM tasty_bytes.raw_pos.menu\n), menu_monthly AS (\n  SELECT\n    DATE_TRUNC('MONTH', oh.order_ts) AS month,\n    m.item_category,\n    m.menu_item_id,\n    ANY_VALUE(m.sale_price_usd) AS sale_price_usd,\n    ANY_VALUE(m.cost_of_goods_usd) AS cost_of_goods_usd\n  FROM __order_detail AS od\n  LEFT OUTER JOIN __order_header AS oh\n    ON od.order_id = oh.order_id\n  LEFT OUTER JOIN __menu AS m\n    ON od.menu_item_id = m.menu_item_id\n  GROUP BY\n    DATE_TRUNC('MONTH', oh.order_ts),\n    m.item_category,\n    m.menu_item_id\n), monthly_category AS (\n  SELECT\n    month,\n    item_category,\n    AVG(sale_price_usd) AS avg_sale_price_usd,\n    AVG(cost_of_goods_usd) AS avg_cost_of_goods_usd\n  FROM menu_monthly\n  GROUP BY\n    month,\n    item_category\n), ranked AS (\n  SELECT\n    month,\n    item_category,\n    avg_sale_price_usd,\n    avg_cost_of_goods_usd,\n    RANK() OVER (PARTITION BY item_category ORDER BY avg_sale_price_usd DESC NULLS LAST) AS rnk\n  FROM monthly_category\n)\nSELECT\n  month,\n  item_category,\n  avg_sale_price_usd,\n  avg_cost_of_goods_usd,\n  rnk\nFROM ranked\nWHERE\n  rnk <= 10\nORDER BY\n  item_category,\n  rnk\n -- Generated by Cortex Analyst (request_id: 4451e43a-0f87-4c92-8b51-09fa24bbb378)\n;", "row_count": 76, "error": ""}
{"ts": "2026-03-17T12:30:04.842459+00:00", "user": "shayantan", "question": "What are the top 10 for what is the average sale price and cost of goods for each item category in the menu broken down by month broken down by category compared to the same period last year?", "sql": "WITH __order_detail AS (\n  SELECT\n    order_id,\n    menu_item_id\n  FROM tasty_bytes.raw_pos.order_detail\n), __order_header AS (\n  SELECT\n    order_id,\n    order_ts\n  FROM tasty_bytes.raw_pos.order_header\n), __menu AS (\n  SELECT\n    menu_item_id,\n    item_category,\n    sale_price_usd,\n    cost_of_goods_usd\n  FROM tasty_bytes.raw_pos.menu\n), menu_monthly AS (\n  SELECT\n    DATE_TRUNC('MONTH', oh.order_ts) AS month,\n    m.item_category,\n    m.menu_item_id,\n    ANY_VALUE(m.sale_price_usd) AS sale_price_usd,\n    ANY_VALUE(m.cost_of_goods_usd) AS cost_of_goods_usd\n  FROM __order_detail AS od\n  LEFT OUTER JOIN __order_header AS oh\n    ON od.order_id = oh.order_id\n  LEFT OUTER JOIN __menu AS m\n    ON od.menu_item_id = m.menu_item_id\n  GROUP BY\n    DATE_TRUNC('MONTH', oh.order_ts),\n    m.item_category,\n    m.menu_item_id\n), monthly_category AS (\n  SELECT\n    month,\n    item_category,\n    AVG(sale_price_usd) AS avg_sale_price_usd,\n    AVG(cost_of_goods_usd) AS avg_cost_of_goods_usd\n  FROM menu_monthly\n  GROUP BY\n    month,\n    item_category\n), yoy_all AS (\n  SELECT\n    curr.month AS curr_month,\n    curr.item_category,\n    curr.avg_sale_price_usd AS curr_avg_sale_price_usd,\n    curr.avg_cost_of_goods_usd AS curr_avg_cost_of_goods_usd,\n    prev.month AS prev_month,\n    prev.avg_sale_price_usd AS prev_avg_sale_price_usd,\n    prev.avg_cost_of_goods_usd AS prev_avg_cost_of_goods_usd,\n    curr.avg_sale_price_usd - prev.avg_sale_price_usd AS sale_price_yoy_chg,\n    (\n      curr.avg_sale_price_usd - prev.avg_sale_price_usd\n    ) / NULLIF(NULLIF(prev.avg_sale_price_usd, 0), 0) AS sale_price_yoy_pct_chg,\n    curr.avg_cost_of_goods_usd - prev.avg_cost_of_goods_usd AS cog_yoy_chg,\n    (\n      curr.avg_cost_of_goods_usd - prev.avg_cost_of_goods_usd\n    ) / NULLIF(NULLIF(prev.avg_cost_of_goods_usd, 0), 0) AS cog_yoy_pct_chg\n  FROM monthly_category AS curr\n  LEFT JOIN monthly_category AS prev\n    ON curr.item_category = prev.item_category\n    AND prev.month = DATEADD(YEAR, -1, curr.month)\n),", "row_count": 12, "error": ""}
