{"ts": "2026-03-17T19:04:07.179728+00:00", "user": "shayantan", "question": "EDA", "sql": "WITH __order_header AS (\n  SELECT\n    order_id,\n    truck_id,\n    location_id,\n    customer_id,\n    order_channel,\n    order_ts,\n    order_total,\n    order_amount\n  FROM tasty_bytes.raw_pos.order_header\n), __order_detail AS (\n  SELECT\n    order_id,\n    menu_item_id,\n    quantity,\n    price AS line_total\n  FROM tasty_bytes.raw_pos.order_detail\n), __menu AS (\n  SELECT\n    menu_item_id,\n    truck_brand_name,\n    menu_item_name,\n    item_category,\n    item_subcategory\n  FROM tasty_bytes.raw_pos.menu\n), __truck AS (\n  SELECT\n    truck_id,\n    country\n  FROM tasty_bytes.raw_pos.truck\n), order_summary AS (\n  SELECT\n    COUNT(DISTINCT oh.order_id) AS total_orders,\n    SUM(oh.order_total) AS total_revenue,\n    SUM(oh.order_amount) AS total_order_amount,\n    MIN(oh.order_ts) AS earliest_order,\n    MAX(oh.order_ts) AS latest_order,\n    COUNT(DISTINCT oh.customer_id) AS unique_customers,\n    COUNT(DISTINCT oh.truck_id) AS unique_trucks,\n    COUNT(DISTINCT oh.location_id) AS unique_locations\n  FROM __order_header AS oh\n), channel_revenue AS (\n  SELECT\n    oh.order_channel,\n    COUNT(DISTINCT oh.order_id) AS num_orders,\n    SUM(oh.order_total) AS total_revenue\n  FROM __order_header AS oh\n  GROUP BY\n    oh.order_channel\n  ORDER BY\n    total_revenue DESC NULLS LAST\n), brand_revenue AS (\n  SELECT\n    m.truck_brand_name,\n    COUNT(DISTINCT od.order_id) AS num_orders,\n    SUM(od.line_total) AS total_revenue\n  FROM __order_detail AS od\n  LEFT OUTER JOIN __menu AS m\n    ON od.menu_item_id = m.menu_item_id\n  GROUP BY\n    m.truck_brand_name\n  ORDER BY\n    total_revenue DESC NULLS LAST\n  LIMIT 10\n), top_menu_items AS (\n  SELECT\n    m.menu_item_name,\n    m.item_category,\n    m.item_subcategory,\n    COUNT(DISTINCT od.order_id) AS num_orders,\n    SUM(od.quantity) AS total_quantity,\n    SUM(od.line_total) AS total_revenue\n  FROM __order_detail AS od\n  LEFT OUTER JOIN __menu AS m\n    ON od.menu_item_id = m.menu_item_id\n  GROUP BY\n    m.menu_item_name,\n    m.item_category,\n    m.item_subcategory", "row_count": 76, "error": ""}
{"ts": "2026-03-17T19:06:01.951849+00:00", "user": "shayantan", "question": "EDA broken down by month?", "sql": "WITH __order_header AS (\n  SELECT\n    order_id,\n    truck_id,\n    customer_id,\n    order_channel,\n    order_ts,\n    order_total,\n    order_amount\n  FROM tasty_bytes.raw_pos.order_header\n), __order_detail AS (\n  SELECT\n    order_id,\n    menu_item_id,\n    price AS line_total\n  FROM tasty_bytes.raw_pos.order_detail\n), __menu AS (\n  SELECT\n    menu_item_id,\n    truck_brand_name,\n    menu_item_name,\n    item_category\n  FROM tasty_bytes.raw_pos.menu\n), __truck AS (\n  SELECT\n    truck_id,\n    country\n  FROM tasty_bytes.raw_pos.truck\n), monthly_summary AS (\n  SELECT\n    DATE_TRUNC('MONTH', oh.order_ts) AS order_month,\n    COUNT(DISTINCT oh.order_id) AS total_orders,\n    SUM(oh.order_total) AS total_revenue,\n    SUM(oh.order_amount) AS total_order_amount,\n    COUNT(DISTINCT oh.customer_id) AS unique_customers\n  FROM __order_header AS oh\n  GROUP BY\n    DATE_TRUNC('MONTH', oh.order_ts)\n), monthly_channel AS (\n  SELECT\n    DATE_TRUNC('MONTH', oh.order_ts) AS order_month,\n    oh.order_channel,\n    COUNT(DISTINCT oh.order_id) AS num_orders,\n    SUM(oh.order_total) AS total_revenue\n  FROM __order_header AS oh\n  GROUP BY\n    DATE_TRUNC('MONTH', oh.order_ts),\n    oh.order_channel\n), monthly_brand AS (\n  SELECT\n    DATE_TRUNC('MONTH', oh.order_ts) AS order_month,\n    m.truck_brand_name,\n    SUM(od.line_total) AS total_revenue,\n    RANK() OVER (\n      PARTITION BY DATE_TRUNC('MONTH', oh.order_ts)\n      ORDER BY SUM(od.line_total) DESC NULLS LAST\n    ) AS rnk\n  FROM __order_detail AS od\n  LEFT OUTER JOIN __order_header AS oh\n    ON od.order_id = oh.order_id\n  LEFT OUTER JOIN __menu AS m\n    ON od.menu_item_id = m.menu_item_id\n  GROUP BY\n    DATE_TRUNC('MONTH', oh.order_ts),\n    m.truck_brand_name\n), monthly_menu AS (\n  SELECT\n    DATE_TRUNC('MONTH', oh.order_ts) AS order_month,\n    m.menu_item_name,\n    m.item_category,\n    SUM(od.line_total) AS total_revenue,\n    RANK() OVER (\n      PARTITION BY DATE_TRUNC('MONTH', oh.order_ts)\n      ORDER BY SUM(od.line_total) DESC NULLS LAST\n    ) A", "row_count": 1117, "error": ""}
{"ts": "2026-03-17T19:07:28.686265+00:00", "user": "shayantan", "question": "describe food trucks", "sql": "WITH __order_detail AS (\n  SELECT\n    order_id,\n    menu_item_id\n  FROM tasty_bytes.raw_pos.order_detail\n), __order_header AS (\n  SELECT\n    order_id,\n    truck_id\n  FROM tasty_bytes.raw_pos.order_header\n), __menu AS (\n  SELECT\n    menu_item_id,\n    menu_type,\n    truck_brand_name\n  FROM tasty_bytes.raw_pos.menu\n), __truck AS (\n  SELECT\n    truck_id,\n    primary_city,\n    region,\n    country,\n    make,\n    model,\n    year,\n    franchise_flag,\n    ev_flag,\n    truck_opening_date\n  FROM tasty_bytes.raw_pos.truck\n), truck_brand_mapping AS (\n  SELECT DISTINCT\n    t.truck_id,\n    m.truck_brand_name,\n    m.menu_type\n  FROM __order_detail AS od\n  LEFT OUTER JOIN __order_header AS oh\n    ON od.order_id = oh.order_id\n  LEFT OUTER JOIN __menu AS m\n    ON od.menu_item_id = m.menu_item_id\n  LEFT OUTER JOIN __truck AS t\n    ON oh.truck_id = t.truck_id\n  WHERE\n    NOT t.truck_id IS NULL AND NOT m.truck_brand_name IS NULL\n), truck_with_brand AS (\n  SELECT\n    t.truck_id,\n    t.country,\n    t.region,\n    t.primary_city,\n    t.make,\n    t.model,\n    t.year,\n    t.franchise_flag,\n    t.ev_flag,\n    t.truck_opening_date,\n    tbm.truck_brand_name,\n    tbm.menu_type\n  FROM __truck AS t\n  LEFT OUTER JOIN truck_brand_mapping AS tbm\n    ON t.truck_id = tbm.truck_id\n), brand_summary AS (\n  SELECT\n    truck_brand_name,\n    menu_type,\n    COUNT(DISTINCT truck_id) AS num_trucks,\n    COUNT(DISTINCT country) AS num_countries,\n    COUNT(DISTINCT region) AS num_regions,\n    COUNT(DISTINCT primary_city) AS num_cities,\n    SUM(franchise_flag) AS num_franchised,\n    SUM(CASE WHEN franchise_flag = 0 THEN 1 ELSE 0 END) AS num_company_owned,\n    SUM(ev_flag) AS num_ev,\n    SUM(CASE WHEN ev_flag = 0 THEN 1 ELSE 0 END) AS num_non_ev,\n    MIN(truck_opening_date) AS earliest_opening,\n    MAX(truck_opening_date) AS latest_opening\n  FROM truck_with_brand\n  GROUP BY\n    truck_brand_name,\n    menu_type\n), country_summary AS (\n  SELECT\n    country,\n    COUNT(DISTINCT truck_id) AS num_trucks\n  FROM __truck\n  GROU", "row_count": 32, "error": ""}
{"ts": "2026-03-17T19:08:21.219239+00:00", "user": "shayantan", "question": "describe food trucks broken down by month?", "sql": "WITH __order_header AS (\n  SELECT\n    order_id,\n    truck_id,\n    order_ts\n  FROM tasty_bytes.raw_pos.order_header\n), __truck AS (\n  SELECT\n    truck_id,\n    country,\n    franchise_flag,\n    ev_flag\n  FROM tasty_bytes.raw_pos.truck\n), __order_detail AS (\n  SELECT\n    order_id,\n    menu_item_id\n  FROM tasty_bytes.raw_pos.order_detail\n), __menu AS (\n  SELECT\n    menu_item_id,\n    truck_brand_name\n  FROM tasty_bytes.raw_pos.menu\n), order_truck_month AS (\n  SELECT\n    DATE_TRUNC('MONTH', oh.order_ts) AS order_month,\n    t.truck_id,\n    t.country,\n    t.franchise_flag,\n    t.ev_flag,\n    m.truck_brand_name\n  FROM __order_header AS oh\n  LEFT OUTER JOIN __truck AS t\n    ON oh.truck_id = t.truck_id\n  LEFT OUTER JOIN __order_detail AS od\n    ON od.order_id = oh.order_id\n  LEFT OUTER JOIN __menu AS m\n    ON od.menu_item_id = m.menu_item_id\n  WHERE\n    NOT t.truck_id IS NULL\n), distinct_trucks_per_month AS (\n  SELECT DISTINCT\n    order_month,\n    truck_id,\n    country,\n    franchise_flag,\n    ev_flag,\n    truck_brand_name\n  FROM order_truck_month\n)\nSELECT\n  order_month,\n  COUNT(DISTINCT truck_id) AS num_distinct_trucks,\n  COUNT(DISTINCT truck_brand_name) AS num_distinct_brands,\n  COUNT(DISTINCT country) AS num_countries,\n  SUM(CASE WHEN franchise_flag = 1 THEN 1 ELSE 0 END) AS num_franchised,\n  SUM(CASE WHEN franchise_flag = 0 THEN 1 ELSE 0 END) AS num_company_owned,\n  SUM(CASE WHEN ev_flag = 1 THEN 1 ELSE 0 END) AS num_ev,\n  SUM(CASE WHEN ev_flag = 0 THEN 1 ELSE 0 END) AS num_non_ev\nFROM distinct_trucks_per_month\nGROUP BY\n  order_month\nORDER BY\n  order_month DESC NULLS LAST\n -- Generated by Cortex Analyst (request_id: 1809f671-e4c1-449a-b87b-5c7591c1c9e3)\n;", "row_count": 47, "error": ""}
{"ts": "2026-03-18T03:28:05.691414+00:00", "user": "shayantan", "question": "What is the total order amount and total order count by order channel for the current year to date?", "sql": "WITH __order_header AS (\n  SELECT\n    order_id,\n    order_channel,\n    order_ts,\n    order_amount\n  FROM tasty_bytes.raw_pos.order_header\n)\nSELECT\n  oh.order_channel,\n  SUM(oh.order_amount) AS total_order_amount,\n  COUNT(DISTINCT oh.order_id) AS total_order_count\nFROM __order_header AS oh\nWHERE\n  DATE_TRUNC('YEAR', oh.order_ts) = DATE_TRUNC('YEAR', CURRENT_DATE)\nGROUP BY\n  oh.order_channel\nORDER BY\n  total_order_amount DESC NULLS LAST\n -- Generated by Cortex Analyst (request_id: 46122ee4-7e73-4ccb-9b35-8be1a46988e7)\n;", "row_count": 0, "error": ""}
{"ts": "2026-03-18T03:32:27.132850+00:00", "user": "shayantan", "question": "What are the top 10 for what is the total order amount and total order count by order channel for the current year to date?", "sql": "WITH __order_header AS (\n  SELECT\n    order_id,\n    order_channel,\n    order_ts,\n    order_amount\n  FROM tasty_bytes.raw_pos.order_header\n)\nSELECT\n  oh.order_channel,\n  SUM(oh.order_amount) AS total_order_amount,\n  COUNT(DISTINCT oh.order_id) AS total_order_count\nFROM __order_header AS oh\nWHERE\n  oh.order_ts >= DATE_TRUNC('YEAR', CURRENT_DATE)\nGROUP BY\n  oh.order_channel\nORDER BY\n  total_order_amount DESC NULLS LAST\nLIMIT 10\n -- Generated by Cortex Analyst (request_id: 8d143531-183a-4753-b7e3-123fd4104399)\n;", "row_count": 0, "error": ""}
{"ts": "2026-03-18T03:33:02.455414+00:00", "user": "shayantan", "question": "What are the top 10 for what is the total order amount and total order count by order channel for the current year to date compared to the same period last year?", "sql": "WITH __order_header AS (\n  SELECT\n    order_id,\n    order_channel,\n    order_ts,\n    order_amount\n  FROM tasty_bytes.raw_pos.order_header\n), ytd_current AS (\n  SELECT\n    oh.order_channel,\n    SUM(oh.order_amount) AS curr_total_order_amount,\n    COUNT(DISTINCT oh.order_id) AS curr_total_order_count\n  FROM __order_header AS oh\n  WHERE\n    oh.order_ts >= DATE_TRUNC('YEAR', CURRENT_DATE) AND oh.order_ts < CURRENT_DATE\n  GROUP BY\n    oh.order_channel\n), ytd_prior AS (\n  SELECT\n    oh.order_channel,\n    SUM(oh.order_amount) AS prior_total_order_amount,\n    COUNT(DISTINCT oh.order_id) AS prior_total_order_count\n  FROM __order_header AS oh\n  WHERE\n    oh.order_ts >= DATE_TRUNC('YEAR', DATEADD(YEAR, -1, CURRENT_DATE))\n    AND oh.order_ts < DATEADD(YEAR, -1, CURRENT_DATE)\n  GROUP BY\n    oh.order_channel\n), ranked AS (\n  SELECT\n    c.order_channel,\n    c.curr_total_order_amount,\n    c.curr_total_order_count,\n    p.prior_total_order_amount,\n    p.prior_total_order_count\n  FROM ytd_current AS c\n  LEFT OUTER JOIN ytd_prior AS p\n    ON c.order_channel = p.order_channel\n  ORDER BY\n    c.curr_total_order_amount DESC NULLS LAST\n  LIMIT 10\n)\nSELECT\n  *\nFROM ranked\nORDER BY\n  curr_total_order_amount DESC NULLS LAST\n -- Generated by Cortex Analyst (request_id: 1ed7dd34-5a54-4be7-b641-13bfacf464e0)\n;", "row_count": 0, "error": ""}
{"ts": "2026-03-18T03:35:25.897185+00:00", "user": "shayantan", "question": "top 10 trucks", "sql": "WITH __order_header AS (\n  SELECT\n    truck_id,\n    order_amount\n  FROM tasty_bytes.raw_pos.order_header\n), __truck AS (\n  SELECT\n    truck_id,\n    primary_city,\n    region,\n    country,\n    make,\n    model,\n    year\n  FROM tasty_bytes.raw_pos.truck\n)\nSELECT\n  oh.truck_id,\n  t.make,\n  t.model,\n  t.year,\n  t.primary_city,\n  t.region,\n  t.country,\n  SUM(oh.order_amount) AS total_order_amount\nFROM __order_header AS oh\nLEFT OUTER JOIN __truck AS t\n  ON oh.truck_id = t.truck_id\nGROUP BY\n  oh.truck_id,\n  t.make,\n  t.model,\n  t.year,\n  t.primary_city,\n  t.region,\n  t.country\nORDER BY\n  total_order_amount DESC NULLS LAST\nLIMIT 10\n -- Generated by Cortex Analyst (request_id: 7bceb8df-e308-45b5-a4d9-985b236a1a09)\n;", "row_count": 10, "error": ""}
{"ts": "2026-03-18T03:35:39.425930+00:00", "user": "shayantan", "question": "top 10 revenue", "sql": "WITH __order_header AS (\n  SELECT\n    truck_id,\n    order_amount\n  FROM tasty_bytes.raw_pos.order_header\n), __truck AS (\n  SELECT\n    truck_id,\n    primary_city,\n    region,\n    country,\n    make,\n    model,\n    year\n  FROM tasty_bytes.raw_pos.truck\n)\nSELECT\n  oh.truck_id,\n  t.make,\n  t.model,\n  t.year,\n  t.primary_city,\n  t.region,\n  t.country,\n  SUM(oh.order_amount) AS total_order_amount\nFROM __order_header AS oh\nLEFT OUTER JOIN __truck AS t\n  ON oh.truck_id = t.truck_id\nGROUP BY\n  oh.truck_id,\n  t.make,\n  t.model,\n  t.year,\n  t.primary_city,\n  t.region,\n  t.country\nORDER BY\n  total_order_amount DESC NULLS LAST\nLIMIT 10\n -- Generated by Cortex Analyst (request_id: e4bcb1b1-b583-4456-bbeb-b2c6e58e3a71)\n;", "row_count": 10, "error": ""}
{"ts": "2026-03-18T03:36:39.422428+00:00", "user": "shayantan", "question": "top 10 revenue", "sql": "WITH __order_header AS (\n  SELECT\n    order_id,\n    order_ts,\n    order_total\n  FROM tasty_bytes.raw_pos.order_header\n)\nSELECT\n  oh.order_id,\n  oh.order_ts,\n  oh.order_total\nFROM __order_header AS oh\nORDER BY\n  oh.order_total DESC NULLS LAST\nLIMIT 10\n -- Generated by Cortex Analyst (request_id: 54d37c91-4ffa-4592-83a1-7eb745c33ff2)\n;", "row_count": 10, "error": ""}
{"ts": "2026-03-18T03:37:03.165841+00:00", "user": "shayantan", "question": "top 10 revenue broken down by month?", "sql": "WITH __order_header AS (\n  SELECT\n    order_ts,\n    order_total\n  FROM tasty_bytes.raw_pos.order_header\n)\nSELECT\n  DATE_TRUNC('MONTH', oh.order_ts) AS month,\n  SUM(oh.order_total) AS total_revenue\nFROM __order_header AS oh\nGROUP BY\n  DATE_TRUNC('MONTH', oh.order_ts)\nORDER BY\n  total_revenue DESC NULLS LAST\nLIMIT 10\n -- Generated by Cortex Analyst (request_id: 9eaeb477-2a18-4fea-8bf0-e3a130e74f56)\n;", "row_count": 10, "error": ""}
